# --- App ---
# Set ENVIRONMENT=production on Railway (enables secure cookies, JSON logs, no SQL echo).
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Database ---
# Local dev:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/churchgate_dashboard
#
# Supabase (use the direct connection string — port 5432, NOT the pooler port 6543).
# The direct connection is required for Postgres advisory locks (APScheduler job dedup)
# and avoids asyncpg prepared-statement issues with PgBouncer transaction mode.
# Get it from: Supabase dashboard → Project Settings → Database → Connection string → URI.
#   postgresql+asyncpg://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
#
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/churchgate_dashboard
# Keep pool size conservative on Supabase free tier (max 60 connections total).
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
#
# TEST_DATABASE_URL must point at a SEPARATE database — the test suite TRUNCATEs
# all tables after every test. Always use a LOCAL Postgres here, never the live
# Supabase DB. Create it once and migrate it:
#   createdb churchgate_dashboard_test
#   DATABASE_URL=$TEST_DATABASE_URL uv run alembic upgrade head
TEST_DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/churchgate_dashboard_test

# --- Freshsales ---
FRESHSALES_DOMAIN=rbpropertieslimited
FRESHSALES_API_KEY=
FRESHSALES_TZ=Africa/Lagos
FRESHSALES_WEBHOOK_SECRET=
FRESHSALES_RATE_LIMIT_PER_HOUR=1000
# Comma-separated Freshsales deal smart-view ids to sync into deals_snapshot.
# Open + Won + Lost cover every non-deleted deal once. Find ids via
# GET /crm/sales/api/deals/filters. Account-specific.
FRESHSALES_DEAL_VIEW_IDS=17001462746,17001462752,17001462751

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:3000

# --- Bookings / Email (SendGrid) ---
# Origin of the standalone booking frontend (added to CORS allow-list).
BOOKING_FRONTEND_BASE_URL=http://localhost:3001
# Timezone used to render booking dates/times in confirmation emails.
BOOKING_TZ=Africa/Lagos
# SendGrid transactional email. Create an API key with "Mail Send" permission at
# https://app.sendgrid.com/settings/api_keys and verify the sender/domain first.
# Leave SENDGRID_API_KEY blank in local dev to skip the actual send (logged instead).
SENDGRID_API_KEY=
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=WTC Abuja Bookings

# --- JWT ---
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=20160

# --- Scheduler ---
RUN_SCHEDULER=true
# Deal sync runs nightly at 03:00 Africa/Lagos (app/main.py) — non-default-pipeline
# deals sync one Freshsales request at a time, so a full pass can take hours.
REFERENCE_SYNC_INTERVAL_HOURS=24
# Run the reference sync on startup. Leave true in prod; set false in local dev so
# `fastapi dev` auto-reloads don't hit Freshsales on every file save (trigger it
# manually via POST /api/v1/admin/sync/reference).
SYNC_ON_STARTUP=true
